# API Keys (Required)
EMBER_API_KEY=your_ember_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# CORS Configuration (Recommended for Vercel deployments)
# Set this to your frontend URL for production deployments
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Alternative: Multiple CORS origins (comma-separated)
# CORS_ORIGINS=https://domain1.com,https://domain2.com

# Environment (Optional - auto-detected on Vercel)
# APP_ENV=development|staging|production

# Logging (Optional)
# LOG_LEVEL=DEBUG|INFO|WARNING|ERROR

# Rate Limiting (Optional - defaults shown)
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=3600 